# 复制本文件为 backend/.env 后填入真实值；切勿提交真实密钥。

# ---------- LLM 后端选择: deepseek | ollama ----------
LLM_PROVIDER=deepseek

# ---------- Ollama（LLM_PROVIDER=ollama 时生效）----------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ---------- DeepSeek（LLM_PROVIDER=deepseek 时生效）----------
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ---------- RAG ----------
RAG_ENABLED=true

# 单数据集（向后兼容）
QDRANT_PATH=database/ros2-kilted-clean/qdrant_store
QDRANT_COLLECTION=ros2_kilted_chunks

# 多数据集（推荐）：path:collection 用逗号分隔
QDRANT_DATASETS=database/ros2-kilted-clean/qdrant_store:ros2_kilted_chunks,database/ros2-tutorial-clean/qdrant_store:ros2_tutorial_chunks

# 检索参数
RAG_TOP_K=5
RAG_RERANK_POOL=12

# 推理设备：cuda:0 / cpu
RAG_DEVICE=cuda:0
